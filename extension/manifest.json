{
  "manifest_version": 3,
  "name": "PRISM Autofill",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/fieldMatcher.js", "content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PRISM Smart Autofill"
  }
}
